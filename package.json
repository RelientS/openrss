{
  "name": "openrss",
  "version": "0.5.0",
  "description": "Turn any website into an RSS feed. Uses agent-browser for automation, openrss for feed management.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "openrss": "./bin/openrss.js"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsup src/index.ts src/cli.ts --format esm --dts",
    "start": "node dist/index.js",
    "openrss": "tsx src/cli.ts"
  },
  "keywords": ["rss", "feed", "browser", "automation", "agent", "agent-browser"],
  "author": "RelientS",
  "repository": {
    "type": "git",
    "url": "https://github.com/RelientS/openrss"
  },
  "license": "MIT",
  "dependencies": {
    "hono": "^4.7.0",
    "@hono/node-server": "^1.14.0",
    "lru-cache": "^11.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.4.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
